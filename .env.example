# FounderOS project-local operator configuration template.
# Copy this file to .env, fill values locally, and never commit .env.
# Leave values as <set locally> in this template only.
# After editing .env, run:
# uv run python scripts/doctor_external_connector_config.py --json

# GitHub read-only
FOS_GITHUB_READONLY_ACCOUNT=<set locally>
FOS_GITHUB_READONLY_TOKEN=<set locally>

# GitHub target organization
FOS_GITHUB_TARGET_ORG=<set locally>

# Jira read-only
FOS_JIRA_READONLY_SITE=<set locally>
FOS_JIRA_READONLY_USER=<set locally>
FOS_JIRA_READONLY_TOKEN=<set locally>

# Jira write dry-run
FOS_JIRA_WRITE_USER=<set locally>
FOS_JIRA_WRITE_TOKEN=<set locally>

# Atlassian Admin dry-run
FOS_ATLASSIAN_ORG_ID=<set locally>
FOS_ATLASSIAN_ADMIN_API_TOKEN_SCOPED=<set locally>
FOS_ATLASSIAN_ADMIN_API_TOKEN_UNSCOPED=<set locally>

# OpenAI
FOS_OPENAI_API_KEY=<set locally>

# Telegram delivery
FOS_TELEGRAM_BOT_TOKEN=<set locally>
FOS_TELEGRAM_CHAT_ID=<set locally>

# Slack delivery
FOS_SLACK_BOT_TOKEN=<set locally>
FOS_SLACK_CHANNEL_ID=<set locally>

# Gmail read-only
FOS_GMAIL_READONLY_CLIENT_ID=<set locally>
FOS_GMAIL_READONLY_CLIENT_SECRET=<set locally>

# Google Drive read-only
FOS_GOOGLE_DRIVE_READONLY_CLIENT_ID=<set locally>
FOS_GOOGLE_DRIVE_READONLY_CLIENT_SECRET=<set locally>

# App settings (optional; uncomment and set in .env when needed).
# The app reads these names directly. FOS_* keys above cover connector
# credentials; FOS_OPENAI_API_KEY and FOS_TELEGRAM_* are aliased into app
# settings automatically.
# ENABLE_LLM=false
# ATTENTION_TRIAGE_ENABLED=false
# EMAIL_ME_ADDRESSES=
# API_AUTH_ENABLED=false
# GOOGLE_GMAIL_BACKFILL_ENABLED=false
# GOOGLE_DRIVE_BACKFILL_ENABLED=false
# GOOGLE_DRIVE_AI_INBOX_FOLDER_ID=
# GOOGLE_CLIENT_SECRETS_FILE=./secrets/google_oauth_client.json
# GOOGLE_TOKEN_FILE=./secrets/google_token.json
# GOOGLE_GMAIL_TOKEN_FILE=./secrets/google_gmail_token.json
# DATABASE_URL and REDIS_URL have working local defaults; override in .env
# only if your Postgres/Redis differ from docker-compose.yml.

# Local dev browser bootstrap (safe; only surfaced to the browser in local)
# These are NOT third-party secrets — only a local dev key + base url +
# feature flags. The browser dev-config endpoint is local-only. See
# docs/dev-env.md for concrete values.
# APP_ENV=local
# FOUNDEROS_API_BASE_URL=<local backend base url>
# FOUNDEROS_DEV_API_KEY=<local dev key>
# FOUNDEROS_ENABLE_BROWSER_DEV_CONFIG=true
# FOUNDEROS_API_KEYS=<local dev key>
#
# External integration secrets stay BACKEND-only and are NEVER sent to the
# browser. Set them in your local env file; leave blank otherwise:
# OPENAI_API_KEY=
# GITHUB_TOKEN=
# JIRA_BASE_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# Legacy/local extra keys
# Keep unsupported local-only keys in .env only when needed.
