# FounderOS environment template.
# Copy to a local env file and replace placeholders outside git.
# Keep all values placeholder-only in this tracked file.

# Core runtime
APP_ENV=<environment>
APP_NAME=<app-name>
API_BASE_URL=<backend-public-base-url>
DATABASE_URL=<postgres-database-url>
REDIS_URL=<redis-url>
RAW_STORAGE_DIR=<raw-storage-directory>

# Backend API auth and secret encryption
# Fail-closed posture: any non-local APP_ENV (e.g. production/private-beta)
# must set API_AUTH_ENABLED=true with a configured API_AUTH_KEY (or
# FOUNDEROS_API_KEYS), or the backend refuses to start. Auth may stay disabled
# only when APP_ENV is local/dev/test.
API_AUTH_ENABLED=<true-or-false>
API_AUTH_KEY=<operator-api-key>
API_AUTH_HEADER_NAME=<api-key-header-name>
FOUNDEROS_API_KEYS=<comma-separated-api-keys>
FOUNDEROS_SECRET_ENCRYPTION_KEY=<stable-encryption-key>

# Backend CORS
FOUNDEROS_CORS_ALLOWED_ORIGINS=<comma-separated-frontend-origins>
FOUNDEROS_CORS_ALLOW_CREDENTIALS=<true-or-false>
CORS_ORIGINS=<comma-separated-frontend-origins>
CORS_ALLOW_CREDENTIALS=<true-or-false>

# Local browser/operator bootstrap
FOUNDEROS_API_BASE_URL=<backend-browser-base-url>
FOUNDEROS_DEV_API_KEY=<local-dev-api-key>
FOUNDEROS_ENABLE_BROWSER_DEV_CONFIG=<true-or-false>
FOUNDEROS_LOCAL_WORKSPACE_PATH=<project local workspace path>

# Private-beta smoke
FOUNDEROS_SMOKE_API_BASE_URL=<backend-smoke-base-url>
FOUNDEROS_SMOKE_API_KEY=<smoke-api-key>
FOUNDEROS_SMOKE_API_KEY_HEADER_NAME=<smoke-api-key-header-name>
FOUNDEROS_SMOKE_OWNER_EMAIL=<smoke-owner-email>
FOUNDEROS_SMOKE_WORKSPACE_ID=<smoke-workspace-id>
FOUNDEROS_SMOKE_EXPECT_AUTH=<true-or-false>
FOUNDEROS_SMOKE_TIMEOUT_SECONDS=<timeout-seconds>

# Frontend build/runtime
NEXT_PUBLIC_API_BASE_URL=<backend-public-base-url>

# Execution gates and GitHub repository scopes
ENABLE_WRITE_ACTIONS=<true-or-false>
REQUIRE_APPROVAL_FOR_WRITES=<true-or-false>
FOS_GITHUB_WRITE_ALLOWED_REPOS=<comma-separated-owner-repo>
FOS_GITHUB_SMOKE_REPO=<owner-repo>
FOS_GITHUB_SYNC_ALLOWED_REPOS=<comma-separated-owner-repo>
FOUNDEROS_GITHUB_REPOS=<comma-separated-owner-repo>

# Read-only connector gates
FOUNDEROS_ENABLE_REAL_CONNECTORS=<true-or-false>
FOUNDEROS_REQUIRE_CONNECTOR_SCOPE=<true-or-false>
FOUNDEROS_CONNECTOR_NETWORK_TIMEOUT_SECONDS=<timeout-seconds>
FOUNDEROS_CONNECTOR_SYNC_LIMIT=<record-limit>
FOUNDEROS_CONNECTOR_BACKFILL_LIMIT=<record-limit>
FOUNDEROS_CONNECTOR_BACKFILL_MAX_DAYS=<day-count>
FOUNDEROS_JIRA_PROJECT_KEYS=<comma-separated-project-keys>

# LLM / AI
ENABLE_LLM=<true-or-false>
OPENAI_API_KEY=<openai-api-key>
FOS_OPENAI_API_KEY=<openai-api-key>

# Obsidian/local export
ENABLE_OBSIDIAN_EXPORT=<true-or-false>
FOUNDEROS_ENABLE_OBSIDIAN_BRIDGE=<true-or-false>
FOUNDEROS_OBSIDIAN_VAULT_NAME=<obsidian-vault-name>
FOUNDEROS_OBSIDIAN_VAULT_PATH=<obsidian-vault-path>
FOUNDEROS_OBSIDIAN_SYNC_MODE=<obsidian-sync-mode>
OBSIDIAN_VAULT_PATH=<obsidian-vault-path>

# Legacy/future provider operator variables retained as placeholders only
FOS_GITHUB_READONLY_ACCOUNT=<github-account>
FOS_GITHUB_READONLY_TOKEN=<github-read-token>
FOS_GITHUB_TARGET_ORG=<github-org>
FOS_JIRA_READONLY_SITE=<jira-site>
FOS_JIRA_READONLY_USER=<jira-user>
FOS_JIRA_READONLY_TOKEN=<jira-read-token>
FOS_JIRA_WRITE_USER=<jira-write-user>
FOS_JIRA_WRITE_TOKEN=<jira-write-token>
FOS_GMAIL_READONLY_CLIENT_ID=<gmail-client-id>
FOS_GMAIL_READONLY_CLIENT_SECRET=<gmail-client-secret>
FOS_GOOGLE_DRIVE_READONLY_CLIENT_ID=<drive-client-id>
FOS_GOOGLE_DRIVE_READONLY_CLIENT_SECRET=<drive-client-secret>
FOS_ATLASSIAN_ORG_ID=<atlassian-org-id>
FOS_ATLASSIAN_ADMIN_API_TOKEN_SCOPED=<atlassian-admin-token-scoped>
FOS_ATLASSIAN_ADMIN_API_TOKEN_UNSCOPED=<atlassian-admin-token-unscoped>
FOS_TELEGRAM_BOT_TOKEN=<telegram-bot-token>
FOS_TELEGRAM_CHAT_ID=<telegram-chat-id>
FOS_SLACK_BOT_TOKEN=<slack-bot-token>
FOS_SLACK_CHANNEL_ID=<slack-channel-id>
