APP_ENV=local
APP_NAME=company-knowledge-os
API_BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+asyncpg://ckdos:ckdos_dev_password@localhost:5432/ckdos
REDIS_URL=redis://localhost:6379/0

RAW_STORAGE_DIR=./raw_storage

ENABLE_LLM=false
ENABLE_WRITE_ACTIONS=false
ENABLE_OBSIDIAN_EXPORT=true
REQUIRE_APPROVAL_FOR_WRITES=true

OPENAI_API_KEY=

GOOGLE_CLIENT_SECRETS_FILE=./secrets/google_oauth_client.json
GOOGLE_TOKEN_FILE=./secrets/google_token.json
GOOGLE_GMAIL_BACKFILL_ENABLED=false
GOOGLE_GMAIL_BACKFILL_QUERY=
GOOGLE_DRIVE_BACKFILL_ENABLED=false
GOOGLE_DRIVE_AI_INBOX_FOLDER_ID=

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=
BITBUCKET_WEBHOOK_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET_TOKEN=

OBSIDIAN_VAULT_PATH=./obsidian_vault
