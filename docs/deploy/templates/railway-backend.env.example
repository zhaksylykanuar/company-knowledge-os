# Railway backend private-beta env names.
# Placeholder-only. Do not commit real values.
APP_ENV=<app-env>
APP_NAME=<app-name>
API_BASE_URL=<railway-backend-domain>
DATABASE_URL=<railway-postgres-url>
REDIS_URL=<railway-redis-url-or-deferred-placeholder>
RAW_STORAGE_DIR=<raw-storage-dir>
API_AUTH_ENABLED=<true-or-false>
API_AUTH_KEY=<operator-api-key>
API_AUTH_HEADER_NAME=<api-key-header-name>
FOUNDEROS_API_KEYS=<comma-separated-api-keys>
FOUNDEROS_SECRET_ENCRYPTION_KEY=<stable-encryption-key>
FOUNDEROS_CORS_ALLOWED_ORIGINS=<railway-frontend-domain>
FOUNDEROS_CORS_ALLOW_CREDENTIALS=<true-or-false>
ENABLE_LLM=<true-or-false>
ENABLE_WRITE_ACTIONS=<true-or-false>
REQUIRE_APPROVAL_FOR_WRITES=<true-or-false>
FOS_GITHUB_WRITE_ALLOWED_REPOS=<comma-separated-owner-repo>
FOS_GITHUB_SYNC_ALLOWED_REPOS=<comma-separated-owner-repo>
FOUNDEROS_ENABLE_REAL_CONNECTORS=<true-or-false>
FOUNDEROS_REQUIRE_CONNECTOR_SCOPE=<true-or-false>
