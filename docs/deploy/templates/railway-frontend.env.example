# Railway frontend private-beta env names.
# Placeholder-only. Do not commit real values.
# Server-only backend URL the Next.js app proxies /api/* and /health to, so the
# session cookie stays first-party. Falls back to NEXT_PUBLIC_API_BASE_URL.
FOUNDEROS_API_PROXY_TARGET=<railway-backend-internal-domain>
NEXT_PUBLIC_API_BASE_URL=<railway-backend-domain>
RAILPACK_BUILD_CMD=<frontend-build-command>
RAILPACK_START_CMD=<frontend-start-command>
