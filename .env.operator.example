# FounderOS local operator runtime env.
# Copy this file to .env.operator and fill only local values there.
# .env.operator is ignored by git and must not be committed.
#
# Keep this file shell-compatible for bash/zsh:
# - use KEY=value or export KEY=value
# - quote values containing spaces
# - do not use command substitutions or shell commands

# ---------------------------------------------------------------------------
# Core app/API runtime
# Required for FOS-036 Gmail validation:
# - API_BASE_URL
# - API_AUTH_ENABLED=true
# - API_AUTH_KEY
# - API_AUTH_HEADER_NAME
# - GOOGLE_GMAIL_BACKFILL_ENABLED=true
# - GOOGLE_GMAIL_BACKFILL_QUERY
# - DATABASE_URL and RAW_STORAGE_DIR when validating persisted counts
#
# API_AUTH_KEY can be any strong local random secret.
# Generate one locally with:
# python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# ---------------------------------------------------------------------------
APP_ENV=local
APP_NAME=FounderOS
API_BASE_URL="<local-api-base-url>"
API_AUTH_ENABLED=true
API_AUTH_KEY="<strong-local-random-secret>"
API_AUTH_HEADER_NAME=x-api-key

DATABASE_URL="<local-postgres-async-url>"
REDIS_URL=""
RAW_STORAGE_DIR="<local-raw-storage-dir>"

# Keep write actions approval-gated. Do not enable direct LLM data mutation.
ENABLE_WRITE_ACTIONS=false
REQUIRE_APPROVAL_FOR_WRITES=true

# Obsidian remains export-only.
ENABLE_OBSIDIAN_EXPORT=false
OBSIDIAN_VAULT_PATH="<local-obsidian-export-dir>"

# ---------------------------------------------------------------------------
# Google OAuth, Gmail, and Drive
# Required for practical Gmail/Drive ingestion:
# - GOOGLE_CLIENT_SECRETS_FILE
# - GOOGLE_GMAIL_TOKEN_FILE for Gmail
# - GOOGLE_TOKEN_FILE for Drive
# - GOOGLE_GMAIL_BACKFILL_ENABLED and GOOGLE_GMAIL_BACKFILL_QUERY
# - GOOGLE_DRIVE_BACKFILL_ENABLED and GOOGLE_DRIVE_AI_INBOX_FOLDER_ID
#
# Use a bounded Gmail query. Replace the placeholder below with a narrow local
# validation query, for example one constrained by date and sender/domain.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_SECRETS_FILE="<local-google-client-secrets-json-file>"
GOOGLE_GMAIL_TOKEN_FILE="<local-gmail-token-json-file>"
GOOGLE_TOKEN_FILE="<local-drive-token-json-file>"

GOOGLE_GMAIL_BACKFILL_ENABLED=true
GOOGLE_GMAIL_BACKFILL_QUERY="after:YYYY/MM/DD before:YYYY/MM/DD from:example.com"

GOOGLE_DRIVE_BACKFILL_ENABLED=false
GOOGLE_DRIVE_AI_INBOX_FOLDER_ID="<drive-folder-id>"

GOOGLE_PUBSUB_TOPIC=""
GOOGLE_PUBSUB_SUBSCRIPTION=""

# ---------------------------------------------------------------------------
# OpenAI/LLM and digest generation
# Required when running LLM-backed extraction or digest generation:
# - ENABLE_LLM=true
# - OPENAI_API_KEY
# Digest reads from Postgres/raw storage; keep evidence-backed facts only.
# ---------------------------------------------------------------------------
ENABLE_LLM=false
OPENAI_API_KEY="<openai-api-key>"
MODEL_CONFIG=""

# ---------------------------------------------------------------------------
# Telegram delivery
# Required for Telegram delivery:
# - TELEGRAM_BOT_TOKEN
# - TELEGRAM_CHAT_ID
# Optional for webhook verification:
# - TELEGRAM_WEBHOOK_SECRET_TOKEN
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="<telegram-bot-token>"
TELEGRAM_CHAT_ID="<telegram-chat-id>"
TELEGRAM_WEBHOOK_SECRET_TOKEN=""

# ---------------------------------------------------------------------------
# Optional external integration secrets
# Fill only when actively using the integration.
# ---------------------------------------------------------------------------
JIRA_BASE_URL=""
JIRA_EMAIL=""
JIRA_API_TOKEN=""
GITHUB_WEBHOOK_SECRET=""
GITLAB_WEBHOOK_SECRET=""
BITBUCKET_WEBHOOK_SECRET=""
