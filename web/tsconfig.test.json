{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".tmp-test",
    "rootDir": ".",
    "types": [
      "node"
    ]
  },
  "include": [
    "components/**/*.tsx",
    "lib/**/*.ts",
    "tests/**/*.test.tsx",
    "tests/**/*.test.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".tmp-test"
  ]
}
